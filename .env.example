# ============================================================
#  India Stock Screener + AI Research Layer — Environment
#  Copy to .env and fill in your keys. Never commit .env!
# ============================================================

# ── EXISTING KEYS (from original screener) ───────────────────
NEWS_API_KEY=your_newsapi_key            # https://newsapi.org  (free 100 req/day)
ALPHA_VANTAGE_KEY=your_av_key           # https://alphavantage.co (free 25 req/day)
TELEGRAM_BOT_TOKEN=your_bot_token       # https://t.me/BotFather
TELEGRAM_CHAT_ID=your_chat_id          # Message @userinfobot to find yours

# ── NEW: AI RESEARCH LAYER ────────────────────────────────────

# Groq (Layer 1 — Fast Triage)
# Sign up: https://console.groq.com  (completely free)
# Free tier: 14,400 tokens/min, 500 req/day
# Model used: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_your_groq_api_key_here

# Google Gemini (Layer 2 — Deep Research)
# Sign up: https://aistudio.google.com/app/apikey  (completely free)
# Free tier: 15 req/min, 1500 req/day for gemini-2.0-flash
# Model used: gemini-2.0-flash-exp
GOOGLE_API_KEY=AIza_your_google_api_key_here

# MarketAux (Stock-specific news with built-in sentiment)
# Sign up: https://www.marketaux.com  (free, no credit card)
# Free tier: 100 requests/day
# Returns: ticker-matched articles with relevance + sentiment scores
MARKETAUX_API_KEY=your_marketaux_token_here

# ── OPTIONAL MANUAL OVERRIDES ─────────────────────────────────
# Set these if you want to override auto-fetched market data
# in the AI research context (useful when markets are closed)
CRUDE_PRICE_MANUAL=      # e.g. 82.50  (USD/barrel)
INR_USD_MANUAL=          # e.g. 83.45

# ── EMAIL (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ── DATABASE ─────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/screener.db

# ── PROXY (optional, helps bypass NSE rate limits) ───────────
HTTP_PROXY=
HTTPS_PROXY=

# ── SCREENER.IN (optional, for better fundamentals) ──────────
SCREENER_SESSION_ID=
